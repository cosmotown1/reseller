@baseUrl = https://cosmotown.com/api/reseller
@token = your_api_key_here
@contentType = application/json

########################################
### HEALTH
########################################

###
GET {{baseUrl}}/ping
x-api-key: {{token}}

###
GET {{baseUrl}}/health

########################################
### DOMAIN CHECK
########################################

###
POST {{baseUrl}}/v2/domain/check
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "domain": "example.com"
}

########################################
### REGISTER (ASYNC - SINGLE)
########################################

###
POST {{baseUrl}}/v2/domain/register
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "domain": "example12393.com",
  "years": 1
}

###
# Set jobId from response manually
@jobId = 26

###
GET {{baseUrl}}/v2/domain/jobs/{{jobId}}
x-api-key: {{token}}

########################################
### REGISTER (ASYNC - BULK)
########################################

###
POST {{baseUrl}}/v2/domain/register
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "domains": [
    {
      "domain": "example12387.com",
      "years": 1
    },
    {
      "domain": "example12388.com",
      "years": 1,
      "ns": [
        "ns1.cosmotown.com",
        "ns2.cosmotown.com"
      ]
    }
  ]
}

########################################
### REGISTER (LEGACY - OPTIONAL)
########################################

###
POST {{baseUrl}}/v2/domain/register
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "items": [
    {
      "name": "example12387.com",
      "years": 1
    }
  ]
}
