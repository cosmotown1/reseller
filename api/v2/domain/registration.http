@baseUrl = https://cosmotown.com/api/reseller
@token = your_api_key_here
@contentType = application/json

########################################
### V2 COMPATIBILITY ONLY
########################################

# For current integration and complete samples, use:
# api/v2.25/domain/registration.http

###
GET {{baseUrl}}/health

###
GET {{baseUrl}}/ping
x-api-key: {{token}}

###
POST {{baseUrl}}/v2/domain/register
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "domain": "example1123.com",
  "years": 1
}

###
GET {{baseUrl}}/v2/domain/register/jobs/216
x-api-key: {{token}}

###
POST {{baseUrl}}/v2/domain/check
Content-Type: {{contentType}}
x-api-key: {{token}}

{
  "domain": "example1123.com"
}
